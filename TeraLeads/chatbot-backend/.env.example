# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_db
DB_USER=postgres
DB_PASSWORD=postgres
# For migrations: DATABASE_URL=postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chatbot_db

# AI Microservice
AI_SERVICE_URL=http://localhost:8000

# CORS
CORS_ORIGIN=http://localhost:3000

# API URL (for Swagger)
API_URL=http://localhost:3001
